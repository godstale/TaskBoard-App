{
  "name": "taskboard-app",
  "version": "0.2.2",
  "description": "Electron desktop app for visualizing TaskOps projects",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "node scripts/rebuild-native.js",
    "start": "electron .",
    "rebuild:native": "node scripts/rebuild-native.js",
    "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "package": "electron-builder --config electron-builder.json5"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "frappe-gantt": "^0.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.42.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.0",
    "vite": "^5.1.5",
    "vitest": "^1.4.0",
    "wait-on": "^7.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "electron", "esbuild"]
  }
}
